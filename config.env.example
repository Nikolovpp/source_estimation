# Local machine paths — copy this file to config.env and fill in your paths.
# config.env is gitignored; this template is tracked.
EEG_PROJECT_ROOT=/path/to/your/EEG/project/root

# Optional: external location(s) for cached ROI timeseries (.npz).
# If the timeseries data lives off the main drive, set one or more
# colon-separated paths so the pipeline can find existing .npz files
# without recomputing.  Each root is tried in order after
# ROI_TIMESERIES_ROOT.  Leave blank or comment out to disable.
# ROI_TIMESERIES_EXTERNAL=/mnt/external1/DECODE_source_space_timeseries:/mnt/external2/DECODE_source_space_timeseries
