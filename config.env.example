# Local machine paths — copy this file to config.env and fill in your paths.
# config.env is gitignored; this template is tracked.
EEG_PROJECT_ROOT=/path/to/your/EEG/project/root

# Optional: external location for cached ROI timeseries (.npz).
# If the timeseries data has been moved off the main drive, set this
# so the pipeline can find existing .npz files without recomputing.
# Leave blank or comment out to disable.
# ROI_TIMESERIES_EXTERNAL=/mnt/external/SVM_source_timeseries
